{
  "paws": [
    {
      "name": "@openvole/paw-shell",
      "allow": { "filesystem": ["./", "/tmp"], "childProcess": true, "env": ["VOLE_SHELL_ALLOWED_DIRS"] }
    }
  ],
  "loop": { "maxIterations": 10, "maxContextTokens": 128000 },
  "heartbeat": { "enabled": false },
  "net": {
    "enabled": true,
    "instanceName": "worker-shell",
    "role": "worker",
    "port": 9701,
    "peers": [ { "url": "http://localhost:9700", "trust": "full" } ],
    "share": { "tools": true, "memory": false }
  }
}
