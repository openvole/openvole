# OpenVole Environment Variables
# Copy this to .env and fill in your values

# Log level: error, warn, info, debug, trace
VOLE_LOG_LEVEL=info

# Dashboard
VOLE_DASHBOARD_PORT=3001

# Brain Paw — Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:latest
# OLLAMA_API_KEY=

# Brain Paw — Anthropic (if using paw-claude)
# ANTHROPIC_API_KEY=

# Brain Paw — OpenAI (if using paw-openai)
# OPENAI_API_KEY=

# Telegram bot
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOW_FROM=123456789,987654321

# GitHub (for paw-mcp GitHub server)
# GITHUB_TOKEN=
