# ============================================
# OpenVole Environment Variables
# Copy this to .env and fill in your values
# ============================================

# --- Core ---

# Log level: error | warn | info | debug | trace
VOLE_LOG_LEVEL=info

# Log file (optional — logs to file in addition to console)
# VOLE_LOG_FILE=.openvole/logs/vole.log

# Vault encryption key (optional — if set, vault values are AES-256 encrypted)
# VOLE_VAULT_KEY=your-secret-key-here

# --- @openvole/paw-brain (unified multi-provider brain) ---

# Provider: anthropic | openai | gemini | xai | ollama
# If not set, auto-detects from available API keys
# BRAIN_PROVIDER=gemini

# Generic vars (used as fallback when provider-specific vars are not set)
# BRAIN_API_KEY=
# BRAIN_MODEL=
# BRAIN_BASE_URL=

# Provider-specific vars (take precedence over generic BRAIN_* vars)

# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# Google Gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# xAI Grok
# XAI_API_KEY=
# XAI_MODEL=grok-3

# Ollama (local)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:latest
# OLLAMA_API_KEY=

# --- @openvole/paw-dashboard ---

VOLE_DASHBOARD_PORT=3001

# --- @openvole/paw-telegram ---

# Get token from @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=123456:ABC-...
# Your Telegram user ID (get from @userinfobot) — comma-separated for multiple
# TELEGRAM_ALLOW_FROM=123456789,987654321

# --- @openvole/paw-slack ---

# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=
# SLACK_APP_TOKEN=xapp-...
# SLACK_ALLOW_FROM=U12345678

# --- @openvole/paw-discord ---

# DISCORD_BOT_TOKEN=
# DISCORD_ALLOW_FROM=123456789012345678

# --- @openvole/paw-whatsapp ---

# WHATSAPP_SESSION_DATA=
# WHATSAPP_ALLOW_FROM=1234567890

# --- @openvole/paw-browser ---

# Set to false to see the browser window (useful for debugging)
# VOLE_BROWSER_HEADLESS=true

# --- @openvole/paw-computer ---

# Delay between mouse actions in ms (default: 100)
# VOLE_COMPUTER_DELAY_MS=100

# --- @openvole/paw-session ---

# Session expiry in minutes (default: 60)
# VOLE_SESSION_TTL=60

# --- @openvole/paw-memory ---

# Custom memory directory (default: .openvole/memory)
# VOLE_MEMORY_DIR=

# --- @openvole/paw-compact ---

# How many recent messages to keep during compaction (default: 10)
# VOLE_COMPACT_KEEP_RECENT=10

# --- @openvole/paw-shell & @openvole/paw-filesystem ---

# Restrict shell/fs operations to these directories
# VOLE_SHELL_ALLOWED_DIRS=./workspace
# VOLE_FS_ALLOWED_DIRS=./workspace

# --- @openvole/paw-github ---

# GITHUB_TOKEN=ghp_...

# --- @openvole/paw-email ---

# SMTP settings (for sending)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=you@gmail.com
# EMAIL_PASS=app-password

# IMAP settings (for reading)
# EMAIL_IMAP_HOST=imap.gmail.com
# EMAIL_IMAP_PORT=993

# --- @openvole/paw-resend ---

# RESEND_API_KEY=re_...

# --- @openvole/paw-calendar ---

# Google Calendar OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
# GOOGLE_CALENDAR_ID=primary

# --- @openvole/paw-tts ---

# ELEVENLABS_API_KEY=
# Or use OpenAI TTS:
# OPENAI_TTS_MODEL=tts-1

# --- @openvole/paw-stt ---

# Uses OPENAI_API_KEY (set above)
# OPENAI_STT_MODEL=whisper-1

# --- @openvole/paw-voice-call ---

# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+1...
