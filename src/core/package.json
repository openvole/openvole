{
  "name": "openvole",
  "version": "1.2.0",
  "description": "Micro-agent core — the minimal loop that makes agentic behavior possible",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "vole": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "croner": "^10.0.1",
    "dotenv": "^16.4.0",
    "execa": "^9.5.0",
    "mitt": "^3.0.1",
    "yaml": "^2.8.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/openvole/openvole",
    "directory": "src/core"
  },
  "homepage": "https://openvole.github.io/openvole/",
  "keywords": [
    "ai",
    "agent",
    "microkernel",
    "llm",
    "tools",
    "mcp"
  ]
}
