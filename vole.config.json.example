{
  "_comment": "OpenVole Configuration — copy to vole.config.json and customize",

  "_comment_brain": "Which paw handles the Think phase (LLM calls). paw-brain supports all providers.",
  "brain": "@openvole/paw-brain",

  "_comment_paws": "Paws to load — use 'vole paw add <name>' to install and auto-configure",
  "paws": [
    {
      "name": "@openvole/paw-brain",
      "allow": {
        "network": ["*"],
        "env": [
          "BRAIN_PROVIDER", "BRAIN_API_KEY", "BRAIN_MODEL", "BRAIN_BASE_URL",
          "ANTHROPIC_API_KEY", "ANTHROPIC_MODEL",
          "OPENAI_API_KEY", "OPENAI_MODEL",
          "GEMINI_API_KEY", "GEMINI_MODEL",
          "XAI_API_KEY", "XAI_MODEL",
          "OLLAMA_HOST", "OLLAMA_MODEL", "OLLAMA_API_KEY"
        ]
      }
    },
    {
      "name": "@openvole/paw-memory",
      "allow": {
        "network": ["*"],
        "env": ["VOLE_MEMORY_DIR", "VOLE_EMBEDDING_PROVIDER", "VOLE_EMBEDDING_MODEL",
                "VOLE_EMBEDDING_DIMS", "VOLE_EMBEDDING_BASE_URL",
                "OLLAMA_HOST", "OPENAI_API_KEY", "GEMINI_API_KEY"]
      }
    },
    {
      "name": "@openvole/paw-session",
      "allow": {
        "env": ["VOLE_SESSION_TTL"]
      }
    },
    {
      "name": "@openvole/paw-compact",
      "allow": {
        "network": ["*"],
        "env": ["VOLE_COMPACT_KEEP_RECENT", "VOLE_COMPACT_MODEL",
                "OLLAMA_HOST", "OPENAI_API_KEY", "GEMINI_API_KEY", "ANTHROPIC_API_KEY"]
      }
    },
    {
      "name": "@openvole/paw-shell",
      "allow": {
        "filesystem": ["./"],
        "env": ["VOLE_SHELL_ALLOWED_DIRS"],
        "childProcess": true
      }
    },
    {
      "name": "@openvole/paw-filesystem",
      "allow": {
        "filesystem": ["./"],
        "env": ["VOLE_FS_ALLOWED_DIRS"]
      }
    },
    {
      "name": "@openvole/paw-dashboard",
      "allow": {
        "listen": [3001],
        "env": ["VOLE_DASHBOARD_PORT"]
      }
    }
  ],

  "_comment_skills": "Skills to load — SKILL.md behavioral recipes",
  "skills": [],

  "loop": {
    "_comment_maxIterations": "Safety limit — max idle agent loop cycles per task (resets on successful tool execution)",
    "maxIterations": 25,

    "_comment_confirmBeforeAct": "If true, asks user confirmation before tool execution",
    "confirmBeforeAct": false,

    "_comment_taskConcurrency": "How many tasks can run simultaneously",
    "taskConcurrency": 1,

    "_comment_compactThreshold": "Legacy: trigger context compaction by message count (0 = disabled). Token-based compaction (75%) is always active.",
    "compactThreshold": 50,

    "_comment_maxContextTokens": "Total token budget for context — adjust based on your LLM's context window",
    "maxContextTokens": 128000,

    "_comment_responseReserve": "Tokens reserved for the LLM response",
    "responseReserve": 4000,

    "_comment_toolHorizon": "If true, Brain starts with core tools only and discovers others via discover_tools. Reduces token usage for large tool sets.",
    "toolHorizon": true,

    "_comment_costTracking": "Cost tracking mode: auto (local ollama=free, cloud=priced), enabled (track all), disabled (no tracking)",
    "costTracking": "auto",

    "_comment_costAlertThreshold": "Warn when a single task exceeds this USD amount (optional)",

    "_comment_rateLimits": "Prevent runaway API costs",
    "rateLimits": {
      "llmCallsPerMinute": 30,
      "llmCallsPerHour": 500,
      "toolExecutionsPerTask": 50,
      "tasksPerHour": {
        "heartbeat": 10,
        "schedule": 20,
        "paw": 100,
        "user": 200
      }
    }
  },

  "_comment_agents": "Named agent profiles for sub-agent spawning. Brain calls spawn_agent({agent: 'researcher'}) to use a profile.",
  "agents": {
    "researcher": {
      "role": "Research Agent",
      "instructions": "Focus on finding accurate, factual information. Cite sources when possible.",
      "allowTools": ["web_fetch", "scrape_page", "memory_search", "memory_write", "workspace_write", "workspace_read"],
      "maxIterations": 15
    },
    "writer": {
      "role": "Content Writer",
      "denyTools": ["shell_exec", "shell_exec_background", "db_execute"],
      "maxIterations": 10
    }
  },

  "_comment_toolProfiles": "Restrict tools by task source — 'paw' covers channel paws (Telegram, Slack, etc.)",
  "toolProfiles": {
    "paw": {
      "deny": ["shell_exec", "shell_exec_background", "fs_write", "fs_edit", "fs_mkdir"]
    }
  },

  "heartbeat": {
    "_comment": "Periodic wake-up — Brain checks HEARTBEAT.md and acts on jobs",
    "enabled": false,
    "intervalMinutes": 30,
    "runOnStart": false
  },

  "security": {
    "_comment_sandboxFilesystem": "Node.js --permission sandbox for subprocess paws (default: true)",
    "sandboxFilesystem": true,

    "_comment_allowedPaths": "Extra paths paws can access outside .openvole/",
    "allowedPaths": [],

    "_comment_docker": "Optional Docker container sandbox — stronger isolation than Node.js --permission. Requires Docker installed.",
    "docker": {
      "enabled": false,
      "image": "node:20-slim",
      "memory": "512m",
      "cpus": "1.0",
      "scope": "session",
      "network": "none"
    }
  },

  "_comment_net": "=== VoleNet — Distributed Agent Networking ===",
  "_comment_net2": "Connect multiple OpenVole instances across machines. Peer-to-peer, no central server required.",
  "_comment_net3": "Authentication via Ed25519 vole-keys (like SSH). Run 'vole net init' to generate keys.",
  "net": {
    "_comment_enabled": "Enable VoleNet networking (default: false — standalone mode)",
    "enabled": false,

    "_comment_instanceName": "Human-readable name for this instance (shown to peers)",
    "instanceName": "my-vole",

    "_comment_role": "Instance role: coordinator (delegates tasks), worker (executes tasks), peer (both)",
    "role": "peer",

    "_comment_port": "Port for VoleNet server (HTTPS + WebSocket)",
    "port": 9700,

    "_comment_keyPath": "Path to Ed25519 keypair (default: .openvole/net/vole_key)",
    "keyPath": ".openvole/net/vole_key",

    "_comment_peers": "Connected peers — URL + trust level + optional tool permissions",
    "peers": [
      {
        "_comment": "Full trust — your own machine, all tools and memory shared",
        "url": "https://192.168.1.50:9700",
        "trust": "full"
      },
      {
        "_comment": "Tool trust — shared server, specific tools only",
        "url": "https://team-server.example.com:9700",
        "trust": "tool",
        "allowTools": ["db_query", "db_schema", "scrape_page"],
        "denyTools": ["shell_exec", "fs_write"]
      },
      {
        "_comment": "Read trust — observer, can search memory but not execute",
        "url": "https://monitor.example.com:9700",
        "trust": "read"
      }
    ],

    "_comment_share": "What to share with peers",
    "share": {
      "_comment_tools": "Expose local tools to peers (peers can call your tools remotely)",
      "tools": true,

      "_comment_memory": "Sync memory writes to peers and include remote results in memory_search",
      "memory": true,

      "_comment_session": "Share session history across instances (same user, multiple devices)",
      "session": false
    },

    "_comment_routing": "Route specific tools to specific peers (pattern: peer-name). Local tools always take priority unless routed.",
    "routing": {
      "image_*": "gpu-server",
      "db_*": "db-server"
    },

    "_comment_tls": "TLS certificates for internet-facing instances (optional for LAN)",
    "tls": {
      "cert": "/path/to/cert.pem",
      "key": "/path/to/key.pem"
    },

    "_comment_discovery": "Peer discovery: manual (config only) or mdns (auto-discover on LAN)",
    "discovery": "manual"
  }
}
